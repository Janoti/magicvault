# Copy to .env for local development: cp .env.example .env

# Database
POSTGRES_USER=magicvault
POSTGRES_PASSWORD=magicvault123
POSTGRES_DB=magicvault

# App
SECRET_KEY=change_this_to_a_long_random_string
ENVIRONMENT=development

# CORS (comma-separated frontend URLs). Not needed for the single-service
# production deploy, only for local dev where frontend runs on :5173.
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Frontend → which backend the dev SPA talks to
VITE_API_URL=http://localhost:8000
